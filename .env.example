# Database
POSTGRES_DB=proplist_db
POSTGRES_USER=proplist_user
POSTGRES_PASSWORD=your_secure_db_password

# Database
DATABASE_URL=postgresql+asyncpg://proplist_user:your_secure_db_password@prop-db:5432/proplist_db

# JWT
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# App
APP_NAME=Property Listing Platform
DEBUG=true
